{
  "version": 2,
  "builds": [
    {
      "src": "api/send-lead.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/send-lead",
      "destination": "/api/send-lead.ts"
    },
    {
      "source": "/((?!robots\\.txt|sitemap\\.xml|favicon\\.ico|api/).*)",
      "destination": "/index.html"
    }
  ]
}
